STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost
STRAVA_AUTH_CODE=
STRAVA_REFRESH_TOKEN=

# Shared secret the scheduled cron must send as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=

# Provided automatically by the Vercel Upstash integration. Only needed locally
# for `npm run strava:seed-upstash` (e.g. via `vercel env pull`).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
